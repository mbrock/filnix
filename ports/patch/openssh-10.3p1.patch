+	dump_digest("client public key NIST:", cp, nist_bytes_len);
+#endif
+	/* success */
+	r = 0;
+	kex->client_pub = buf;
+	buf = NULL;
+ out:
+	sshbuf_free(buf);
+        if (r == SSH_ERR_LIBCRYPTO_ERROR)
+	   ERR_print_errors_fp(stderr);
